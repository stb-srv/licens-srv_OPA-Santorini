PORT=4000
ADMIN_SECRET=your-very-secret-admin-jwt-key
HMAC_SECRET=your-very-secret-hmac-key

# FIX SEC-03: Setup-Endpoint Absicherung
# SETUP_TOKEN muss gesetzt sein, damit POST /api/v1/setup ausgefuehrt werden kann.
# Ohne diesen Token kann niemand den ersten Admin-Account anlegen – auch nicht
# wenn config.json fehlt oder geloescht wurde.
# Generiere einen sicheren Zufallswert: openssl rand -hex 32
SETUP_TOKEN=change-this-to-a-very-secret-setup-token

# STUFE 1: RSA Private Key fuer signierte License Tokens (RS256)
# Generiere ein neues Schlüsselpaar: openssl genrsa -out private.pem 2048
# Dann: openssl rsa -in private.pem -pubout -out public.pem
# Den Inhalt von private.pem hier eintragen (\n durch literal newlines ersetzen oder inline mit \n)
# ACHTUNG: Dieser Key muss geheim bleiben! Niemals committen!
RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...dein private key hier...\n-----END PRIVATE KEY-----"

CORS_ORIGINS=https://deine-domain.de,https://cms.deine-domain.de

# MySQL Datenbank
DB_HOST=10.35.46.188
DB_PORT=3306
DB_NAME=k220163_opa
DB_USER=k220163_opa
DB_PASS=your-db-password-here

# SMTP Konfiguration (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Webhook URL (optional) - wird bei Lizenz-Statusänderungen aufgerufen
WEBHOOK_URL=
WEBHOOK_SECRET=your-webhook-secret
