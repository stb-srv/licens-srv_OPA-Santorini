PORT=4000
ADMIN_SECRET=your-very-secret-admin-jwt-key
HMAC_SECRET=your-very-secret-hmac-key

# STUFE 1: RSA Private Key fuer signierte License Tokens (RS256)
# Generiere ein neues Schlüsselpaar: openssl genrsa -out private.pem 2048
# Dann: openssl rsa -in private.pem -pubout -out public.pem
# Den Inhalt von private.pem hier eintragen (\n durch literal newlines ersetzen oder inline mit \n)
# ACHTUNG: Dieser Key muss geheim bleiben! Niemals committen!
RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...dein private key hier...\n-----END PRIVATE KEY-----"

CORS_ORIGINS=https://deine-domain.de,https://cms.deine-domain.de

# SMTP Konfiguration (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
